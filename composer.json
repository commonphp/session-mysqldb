{
  "name": "comphp/session-mysqldb",
  "type": "library",
  "description": "Session Driver for CommonPHP that reads/stores session data in a MySQL Database",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Drivers\\Session\\MySQL\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Drivers\\Session\\MySQL\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "comphp/session": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}
